{
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@engine/core": "workspace:*",
    "@engine/rendering": "workspace:*",
    "@engine/user": "workspace:*",
    "low-level": "workspace:*"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -b && tsc-alias -p tsconfig.json && pnpm run parcel",
    "parcel": "parcel build dist/index.js --dist-dir . --no-source-maps --no-content-hash",
    "clean": "tsc -b --clean"
  }
}
